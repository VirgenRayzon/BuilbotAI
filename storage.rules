rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      // Only Managers or Super Admins can upload/overwrite images
      allow write: if request.auth != null && 
                   (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isManager == true ||
                    firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true);
    }
  }
}

