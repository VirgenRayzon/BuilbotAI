
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isManager() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isManager == true;
    }

    function isSuperAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
    }

    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId || isManager();
      allow create: if request.auth.uid == userId;
    }

    match /authKeys/{keyId} {
      allow get: if true;
      allow list, write: if request.auth != null && isSuperAdmin();
    }

    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isManager());
      allow update: if isManager();
    }

    match /notifications/{notifId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /system_notifications/{notifId} {
      allow read, write: if isManager();
    }

    match /{category}/{partId} {
      allow read: if true;
      allow update: if request.auth != null && 
                    category in ['CPU', 'GPU', 'Motherboard', 'RAM', 'Storage', 'PSU', 'Case', 'Cooler'] &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'popularity']);
      allow write: if isManager();
    }
  }
}
