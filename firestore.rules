
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isManager() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isManager', false) == true;
    }

    function isSuperAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuperAdmin', false) == true;
    }

    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId || isManager();
      allow create: if request.auth.uid == userId;
    }

    match /authKeys/{keyId} {
      allow get: if true;
      allow list, write: if request.auth != null && isSuperAdmin();
    }

    match /keyRequests/{requestId} {
      allow create: if true;
      allow read, write: if isSuperAdmin();
    }

    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isManager());
      // Users can cancel their own orders
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.userId && request.resource.data.status == 'cancelled') ||
        isManager()
      );
      allow delete: if request.auth != null && (
        (request.auth.uid == resource.data.userId && resource.data.status == 'cancelled') || 
        isManager()
      );
    }

    match /notifications/{notifId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /system_notifications/{notifId} {
      allow read, write: if isManager();
    }

    // Broad match for part categories only
    match /{category}/{partId} {
      allow read: if true;
      allow update: if request.auth != null && 
                    category in ['CPU', 'GPU', 'Motherboard', 'RAM', 'Storage', 'PSU', 'Case', 'Cooler', 'Monitor', 'Keyboard', 'Mouse', 'Headset'] &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'popularity']);
      allow write: if isManager();
    }
  }
}
