
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isManager() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isManager == true;
    }

    function isSuperAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
    }

    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId || isManager();
      allow create: if request.auth.uid == userId;
    }

    match /authKeys/{keyId} {
      allow get: if true;
      allow list, write: if request.auth != null && isSuperAdmin();
    }

    match /{category}/{partId} 
        where category in ['CPU', 'GPU', 'Motherboard', 'RAM', 'Storage', 'PSU', 'Case', 'Cooler', 'prebuiltSystems'] {
      allow read: if true;
      allow write: if isManager();
    }
  }
}
